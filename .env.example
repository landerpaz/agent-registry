# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/agent_registry
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_CHANNEL=agent_registry_events

# Okta — set OKTA_VALIDATION_ENABLED=false for local dev (no token required)
OKTA_VALIDATION_ENABLED=true
OKTA_ISSUER=https://your-domain.okta.com/oauth2/default
OKTA_AUDIENCE=api://agent-registry
OKTA_JWKS_URI=https://your-domain.okta.com/oauth2/default/v1/keys

# Health Check
HEALTH_CHECK_INTERVAL_SECONDS=3600
HEALTH_CHECK_TIMEOUT_SECONDS=10

# Pagination
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100
